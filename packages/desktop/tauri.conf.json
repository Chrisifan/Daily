{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Daily",
  "version": "0.1.0",
  "identifier": "com.daily.app",
  "build": {
    "beforeDevCommand": "pnpm -w run dev:app",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm -w run build:app",
    "frontendDist": "../web/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Daily",
        "width": 1200,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./smart-workbench.entitlements"
    }
  }
}
